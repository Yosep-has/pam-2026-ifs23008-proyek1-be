## Global Variabel
@BaseUrl = https://pam-2026-ifs23008-proyek1-be.yosep.fun:8080/
### ---------------------------------------
## Auth
### ---------------------------------------

### Melakukan pendaftaran
# @name PostRegister
POST {{BaseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Tester",
  "username": "tester",
  "password": "tester"
}

### Masuk ke layanan
# @name PostLogin
POST {{BaseUrl}}/auth/login
Content-Type: application/json

{
  "username": "des",
  "password": "13"
}

> {%
    client.global.set("authToken", response.body.data.authToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### Refresh token
# @name PostRefreshToken
POST {{BaseUrl}}/auth/refresh-token
Content-Type: application/json

{
  "authToken": "{{authToken}}",
  "refreshToken": "{{refreshToken}}"
}

> {%
    client.global.set("authToken", response.body.data.authToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### Keluar dari layanan
# @name PostLogout
POST {{BaseUrl}}/auth/logout
Content-Type: application/json

{
  "authToken": "{{authToken}}"
}

### ---------------------------------------
## Users
### ---------------------------------------

### Mengambil informasi akun
# @name GetUserMe
GET {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

> {%
    client.global.set("userId", response.body.data.user.id);
%}

### Mengubah informasi akun
# @name PutUserMe
PUT {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Tester Update",
  "username": "tester"
}

### Mengubah kata sandi akun
# @name PutUserMePassword
PUT {{BaseUrl}}/users/me/password
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "newPassword": "tester",
  "password": "tester"
}

### Mengubah photo profile
# @name PutUserMePhoto
PUT {{BaseUrl}}/users/me/photo
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< ./uploads/examples/me.png
--WebAppBoundary--

### Mengambil photo profile
@userId = 00ed9d33-61b0-48b7-a32a-6510af028731

# @name GetMyPhoto
GET {{BaseUrl}}/images/users/{{userId}}
Authorization: Bearer {{authToken}}

### ---------------------------------------
## Farms
### ---------------------------------------

### Mengambil semua data farm (tanpa filter)
# @name GetFarms
GET {{BaseUrl}}/farms
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengambil semua data farm dengan search
# @name GetFarmsSearch
GET {{BaseUrl}}/farms?search=babi
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengambil semua data farm - filter sudah vaksin
# @name GetFarmsDone
GET {{BaseUrl}}/farms?filter=done
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengambil semua data farm - filter belum vaksin
# @name GetFarmsNotDone
GET {{BaseUrl}}/farms?filter=not_done
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengambil semua data farm dengan pagination
# @name GetFarmsPaged
GET {{BaseUrl}}/farms?page=1&limit=10
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengambil semua data farm dengan semua parameter
# @name GetFarmsAll
GET {{BaseUrl}}/farms?search=&filter=all&page=1&limit=10
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Menambahkan farm
# @name PostFarm
POST {{BaseUrl}}/farms
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Farm Ayam",
  "description": "Farm ayam petelur",
  "isDone": false,
  "lastVaccinationDate": null
}

> {%
    client.global.set("farmId", response.body.data.farmId);
%}

### Mengambil farm berdasarkan id
# @name GetFarmById
GET {{BaseUrl}}/farms/{{farmId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### Mengubah farm
# @name PutFarm
PUT {{BaseUrl}}/farms/{{farmId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title": "Farm Ayam Update",
  "description": "Farm ayam petelur sudah vaksin",
  "isDone": true,
  "lastVaccinationDate": "2024-01-15T00:00:00Z"
}

### Mengubah cover farm
# @name PutFarmCover
PUT {{BaseUrl}}/farms/{{farmId}}/cover
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< ./uploads/examples/me.png
--WebAppBoundary--

### Mengambil cover farm
# @name GetFarmCover
GET {{BaseUrl}}/images/farms/{{farmId}}
Authorization: Bearer {{authToken}}

### Menghapus farm
# @name DeleteFarm
DELETE {{BaseUrl}}/farms/{{farmId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json
